<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!--
        Manual "paste link" row — a fallback for testing/using the downloader
        when you don't want to rely on the clipboard listener (e.g. some
        keyboards/OEM ROMs don't fire OnPrimaryClipChangedListener reliably,
        or you're pasting from a share sheet instead of the clipboard).
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/linkInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Paste a link here"
            android:inputType="textUri"
            android:maxLines="1"
            android:importantForAutofill="no"
            tools:ignore="LabelFor" />

        <ImageButton
            android:id="@+id/pasteButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Paste from clipboard"
            android:src="@android:drawable/ic_menu_edit"
            android:padding="8dp" />

        <Button
            android:id="@+id/downloadButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Download" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/downloadsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/emptyStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="32dp"
            android:gravity="center"
            android:text="No downloads yet.\nCopy a Pinterest, Instagram, or TikTok link — or paste one above — to get started."
            android:textSize="15sp"
            android:textColor="#888888" />

    </FrameLayout>

</LinearLayout>
